# Database
POSTGRES_DB=article_archive
POSTGRES_USER=archive
POSTGRES_PASSWORD=archive
DB_PORT=5432
PROD_DOCKER_NETWORK=arkeep-prod-net

# Backend (FastAPI)
# DATABASE_URL is constructed from POSTGRES_* vars in docker-compose files.
# Override explicitly if needed: postgresql+asyncpg://user:pass@host:5432/dbname
JWT_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=3000
BACKEND_ORIGIN=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=/backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Nginx (prod)
NGINX_PORT=8080
