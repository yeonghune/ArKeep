# Database
POSTGRES_DB=article_archive
POSTGRES_USER=archive
POSTGRES_PASSWORD=archive
DB_PORT=5432
PROD_DOCKER_NETWORK=arkeep-prod-net

# Backend
# When using docker-compose.prod.db.yml, keep host as db on the shared Docker network.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/article_archive
SPRING_DATASOURCE_USERNAME=archive
SPRING_DATASOURCE_PASSWORD=archive
JWT_SECRET=change-me-to-a-long-random-secret-change-me-to-a-long-random-secret
GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=3000
BACKEND_ORIGIN=http://backend:8080
NEXT_PUBLIC_API_BASE_URL=/backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=407067016927-ruqhp1lbrbi00a114g5niv3euif15buf.apps.googleusercontent.com

# Nginx (prod)
NGINX_PORT=8080
